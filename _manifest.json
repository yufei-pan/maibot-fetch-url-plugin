{
  "manifest_version": 2,
  "id": "com.0-hz.fetch-url",
  "version": "0.1.0",
  "name": "Fetch URL",
  "description": "提供 fetch_url 工具：抓取任意 URL，网页 / PDF 通过 jina.ai Reader（或本地 markdownify 兜底）转为 Markdown，图片自动转码压缩后直接回传给麦麦观察。支持分页读取、超长内容 LLM 总结、VLM 图片描述替换 alt 文本。",
  "author": {
    "name": "kes",
    "url": "https://github.com/yufei-pan"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/yufei-pan/maibot-fetch-url-plugin",
    "homepage": "https://github.com/yufei-pan/maibot-fetch-url-plugin",
    "documentation": "https://github.com/yufei-pan/maibot-fetch-url-plugin/blob/main/README.md",
    "issues": "https://github.com/yufei-pan/maibot-fetch-url-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.26.0"
    },
    {
      "type": "python_package",
      "name": "markdownify",
      "version_spec": ">=0.11.0"
    },
    {
      "type": "python_package",
      "name": "beautifulsoup4",
      "version_spec": ">=4.12.0"
    },
    {
      "type": "python_package",
      "name": "pillow",
      "version_spec": ">=10.0.0"
    }
  ],
  "capabilities": [
    "config.get",
    "llm.generate",
    "llm.get_available_models"
  ],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
